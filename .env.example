# Base wallet private key
# Used for x402 payments on steps 3 and 4 — needs a small USDC balance on Base
PRIVATE_KEY=0x...

# Recipient wallet address
RECIPIENT_ADDRESS=0x...

# Recipient name — checked against GLEIF registry in step 4
RECIPIENT_NAME=Acme Corp

# Settlement amount in USD (default: 50000)
AMOUNT_USD=50000

# Settlement mode
# true  = oracle and compliance run live, nothing moves on-chain (default)
# false = live on-chain settlement — wallet needs USDC >= gross amount
SANDBOX=true
